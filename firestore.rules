rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "carlisat19@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isSeller(sellerId) {
      return isAuthenticated() && 
        (
          request.auth.uid == sellerId || 
          (exists(/databases/$(database)/documents/sellers/$(sellerId)) && 
           get(/databases/$(database)/documents/sellers/$(sellerId)).data.email.lower() == request.auth.token.email.lower())
        );
    }

    function isOrderOwner(orderData) {
      return isAuthenticated() && (
        ('userId' in orderData && request.auth.uid == orderData.userId) ||
        ('sellerIds' in orderData && request.auth.uid in orderData.sellerIds)
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['email', 'displayName']) &&
             data.email is string && data.email.size() < 256 &&
             data.displayName is string && data.displayName.size() < 100 &&
             (!('role' in data) || data.role in ['admin', 'seller', 'client']) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 20)) &&
             (!('location' in data) || (data.location is string && data.location.size() < 500)) &&
             (!('city' in data) || (data.city is string && data.city.size() < 100));
    }

    function isValidSeller(data) {
      return hasRequiredFields(['name', 'email', 'status', 'joinedDate']) &&
             hasOnlyAllowedFields(['name', 'email', 'status', 'joinedDate', 'id']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string &&
             data.status in ['Active', 'Suspended'] &&
             data.joinedDate is string;
    }

    function isValidProduct(data) {
      return hasRequiredFields(['name', 'brand', 'price', 'image', 'category', 'gender', 'color', 'description', 'inStock', 'sellerId']) &&
             hasOnlyAllowedFields(['name', 'brand', 'price', 'originalPrice', 'image', 'images', 'category', 'gender', 'color', 'colors', 'description', 'inStock', 'sellerId', 'id', 'isNew']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.brand is string &&
             data.price is number && data.price >= 0 &&
             (!('originalPrice' in data) || (data.originalPrice is number && data.originalPrice >= 0)) &&
             data.image is string &&
             (!('images' in data) || data.images is list) &&
             data.category is string &&
             data.gender in ['Men', 'Women', 'Unisex', 'Kids'] &&
             data.color is string &&
             (!('colors' in data) || data.colors is list) &&
             data.description is string && data.description.size() < 2000 &&
             data.inStock is bool &&
             data.sellerId is string;
    }

    function isValidOrder(data) {
      return hasRequiredFields(['customerInfo', 'items', 'total', 'status', 'date', 'paymentMethod']) &&
             hasOnlyAllowedFields(['customerInfo', 'items', 'total', 'status', 'date', 'paymentMethod', 'userId', 'sellerIds', 'id', 'deliveryFee', 'mpesaCheckoutId', 'paymentStatus', 'mpesaReceipt', 'paymentError', 'paidAt', 'verificationMethod']) &&
             data.customerInfo is map &&
             data.customerInfo.keys().hasAll(['firstName', 'lastName', 'email', 'phone', 'location', 'city']) &&
             data.items is list &&
             data.total is number && data.total >= 0 &&
             (!('deliveryFee' in data) || (data.deliveryFee is number && data.deliveryFee >= 0)) &&
             data.status in ['Pending', 'Processing', 'Shipped', 'Delivered', 'Cancelled'] &&
             data.date is string &&
             data.paymentMethod is string &&
             (!('mpesaCheckoutId' in data) || data.mpesaCheckoutId is string) &&
             (!('paymentStatus' in data) || data.paymentStatus in ['Paid', 'Failed', 'Pending']) &&
             (!('mpesaReceipt' in data) || (data.mpesaReceipt is string && data.mpesaReceipt.size() < 20)) &&
             (!('verificationMethod' in data) || data.verificationMethod in ['Automatic', 'Manual']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /sellers/{sellerId} {
      allow read: if true; 
      allow create: if (isAdmin() || request.auth.uid == sellerId) && isValidSeller(request.resource.data);
      allow update: if (isAdmin() || isSeller(sellerId)) && isValidSeller(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidProduct(request.resource.data) && (isAdmin() || isSeller(request.resource.data.sellerId));
      allow update: if isAuthenticated() && isValidProduct(request.resource.data) && (isAdmin() || isSeller(resource.data.sellerId));
      allow delete: if isAdmin() || (isAuthenticated() && isSeller(resource.data.sellerId));
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || isOrderOwner(resource.data);
      allow create: if isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
