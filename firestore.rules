rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "carlisat19@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isSeller(sellerId) {
      return isAuthenticated() && 
        (
          request.auth.uid == sellerId || 
          (exists(/databases/$(database)/documents/sellers/$(sellerId)) && 
           get(/databases/$(database)/documents/sellers/$(sellerId)).data.email.lower() == request.auth.token.email.lower())
        );
    }

    function isOrderOwner(orderData) {
      return isAuthenticated() && (
        ('userId' in orderData && request.auth.uid == orderData.userId) ||
        ('sellerIds' in orderData && request.auth.uid in orderData.sellerIds)
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['email', 'displayName']) &&
             data.email is string && data.email.size() < 256 &&
             data.displayName is string && data.displayName.size() < 100 &&
             (!('role' in data) || data.role in ['admin', 'seller', 'client']) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 20)) &&
             (!('location' in data) || (data.location is string && data.location.size() < 500)) &&
             (!('city' in data) || (data.city is string && data.city.size() < 100));
    }

    function isValidSeller(data) {
      return hasRequiredFields(['name', 'email', 'status', 'joinedDate']) &&
             hasOnlyAllowedFields(['name', 'email', 'status', 'joinedDate', 'id']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string &&
             data.status in ['Active', 'Suspended'] &&
             data.joinedDate is string;
    }

    function isValidProduct(data, isUpdate) {
      return (isUpdate || hasRequiredFields(['name', 'brand', 'price', 'image', 'category', 'gender', 'color', 'description', 'inStock', 'sellerId'])) &&
             hasOnlyAllowedFields(['name', 'brand', 'price', 'originalPrice', 'image', 'images', 'category', 'gender', 'color', 'colors', 'description', 'inStock', 'sellerId', 'id', 'isNew', 'stock']) &&
             (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() < 200)) &&
             (!('brand' in data) || data.brand is string) &&
             (!('price' in data) || (data.price is number && data.price >= 0)) &&
             (!('originalPrice' in data) || (data.originalPrice is number && data.originalPrice >= 0)) &&
             (!('image' in data) || data.image is string) &&
             (!('images' in data) || data.images is list) &&
             (!('category' in data) || data.category is string) &&
             (!('gender' in data) || data.gender in ['Men', 'Women', 'Unisex', 'Kids']) &&
             (!('color' in data) || data.color is string) &&
             (!('colors' in data) || data.colors is list) &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             (!('inStock' in data) || data.inStock is bool) &&
             (!('stock' in data) || (data.stock is number && data.stock >= 0)) &&
             (!('sellerId' in data) || data.sellerId is string);
    }

    function isValidOrder(data, isUpdate) {
      return (isUpdate || hasRequiredFields(['customerInfo', 'items', 'total', 'status', 'date', 'paymentMethod'])) &&
             hasOnlyAllowedFields(['customerInfo', 'items', 'total', 'status', 'date', 'paymentMethod', 'userId', 'sellerIds', 'id', 'deliveryFee', 'mpesaCheckoutId', 'paymentStatus', 'mpesaReceipt', 'paymentError', 'paidAt', 'verificationMethod', 'intasendInvoiceId', 'intasendTransactionId']) &&
             (!('customerInfo' in data) || (data.customerInfo is map && data.customerInfo.keys().hasAll(['firstName', 'lastName', 'email', 'phone', 'location', 'city']))) &&
             (!('items' in data) || data.items is list) &&
             (!('total' in data) || (data.total is number && data.total >= 0)) &&
             (!('deliveryFee' in data) || (data.deliveryFee is number && data.deliveryFee >= 0)) &&
             (!('status' in data) || data.status in ['Pending', 'Processing', 'Shipped', 'Delivered', 'Cancelled']) &&
             (!('date' in data) || data.date is string) &&
             (!('paymentMethod' in data) || data.paymentMethod is string) &&
             (!('mpesaCheckoutId' in data) || data.mpesaCheckoutId is string) &&
             (!('paymentStatus' in data) || data.paymentStatus in ['Paid', 'Failed', 'Pending']) &&
             (!('mpesaReceipt' in data) || (data.mpesaReceipt is string && data.mpesaReceipt.size() < 20)) &&
             (!('intasendInvoiceId' in data) || data.intasendInvoiceId is string) &&
             (!('intasendTransactionId' in data) || data.intasendTransactionId is string) &&
             (!('verificationMethod' in data) || data.verificationMethod in ['Automatic', 'Manual']);
    }

    function isValidReview(data) {
      return hasRequiredFields(['productId', 'userId', 'userName', 'rating', 'comment', 'createdAt']) &&
             data.productId is string &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() > 0 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() < 2000 &&
             data.createdAt is string;
    }

    function isValidSiteSettings(data) {
      return data.keys().size() > 0;
    }

    function isValidContactMessage(data) {
      return hasRequiredFields(['name', 'email', 'message', 'status', 'createdAt']) &&
             data.name is string && data.email is string && data.message is string &&
             data.status in ['unread', 'read', 'replied'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /sellers/{sellerId} {
      allow read: if true; 
      allow create: if (isAdmin() || request.auth.uid == sellerId) && isValidSeller(request.resource.data);
      allow update: if (isAdmin() || isSeller(sellerId)) && isValidSeller(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidProduct(request.resource.data, false) && (isAdmin() || isSeller(request.resource.data.sellerId));
      allow update: if isAuthenticated() && isValidProduct(request.resource.data, true) && (isAdmin() || isSeller(resource.data.sellerId));
      allow delete: if isAdmin() || (isAuthenticated() && isSeller(resource.data.sellerId));

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidReview(request.resource.data);
        allow update, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      }
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || isOrderOwner(resource.data);
      allow create: if isValidOrder(request.resource.data, false);
      allow update: if isAdmin() && isValidOrder(request.resource.data, true);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSiteSettings(request.resource.data);
    }

    match /content_blocks/{blockId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /homepage_sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contact_messages/{messageId} {
      allow create: if isValidContactMessage(request.resource.data);
      allow read, update, delete: if isAdmin();
    }
  }
}
