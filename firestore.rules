rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'seller')
    //
    // Collection: sellers
    // Document ID: {sellerId}
    // Fields:
    //   - name: string (required)
    //   - email: string (required)
    //   - status: string (required)
    //   - joinedDate: string (required)
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - name: string (required)
    //   - brand: string (required)
    //   - price: number (required)
    //   - image: string (required)
    //   - category: string (required)
    //   - gender: string (required)
    //   - color: string (required)
    //   - description: string (required)
    //   - inStock: boolean (required)
    //   - sellerId: string (required)
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - customerInfo: map (required)
    //   - items: list (required)
    //   - total: number (required)
    //   - status: string (required)
    //   - date: string (required)
    //   - paymentMethod: string (required)
    //   - userId: string (optional, for tracking customer orders)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "carlisat19@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isSeller(sellerId) {
      return isAuthenticated() && request.auth.uid == sellerId;
    }

    function isOrderOwner(orderData) {
      return isAuthenticated() && (
        ('userId' in orderData && request.auth.uid == orderData.userId) ||
        ('sellerIds' in orderData && request.auth.uid in orderData.sellerIds)
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['email', 'displayName']) &&
             data.email is string &&
             data.displayName is string &&
             (!('role' in data) || data.role in ['admin', 'seller']);
    }

    function isValidSeller(data) {
      return hasRequiredFields(['name', 'email', 'status', 'joinedDate']) &&
             hasOnlyAllowedFields(['name', 'email', 'status', 'joinedDate', 'id']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string &&
             data.status in ['Active', 'Suspended'] &&
             data.joinedDate is string;
    }

    function isValidProduct(data) {
      return hasRequiredFields(['name', 'brand', 'price', 'image', 'category', 'gender', 'color', 'description', 'inStock', 'sellerId']) &&
             hasOnlyAllowedFields(['name', 'brand', 'price', 'image', 'category', 'gender', 'color', 'description', 'inStock', 'sellerId', 'id', 'isNew']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.brand is string &&
             data.price is number && data.price >= 0 &&
             data.image is string &&
             data.category is string &&
             data.gender in ['Men', 'Women', 'Unisex', 'Kids'] &&
             data.color is string &&
             data.description is string && data.description.size() < 2000 &&
             data.inStock is bool &&
             data.sellerId is string;
    }

    function isValidOrder(data) {
      return hasRequiredFields(['customerInfo', 'items', 'total', 'status', 'date', 'paymentMethod']) &&
             data.customerInfo is map &&
             data.items is list &&
             data.total is number && data.total >= 0 &&
             data.status in ['Pending', 'Processing', 'Shipped', 'Delivered', 'Cancelled'] &&
             data.date is string &&
             data.paymentMethod is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      // Only admins can create/update users, or a user can create their own initial profile
      allow create: if (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);
      allow update: if (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /sellers/{sellerId} {
      allow read: if true; 
      allow create: if (isAdmin() || request.auth.uid == sellerId) && isValidSeller(request.resource.data);
      allow update: if (isAdmin() || isSeller(sellerId)) && isValidSeller(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidProduct(request.resource.data) && (isAdmin() || isSeller(request.resource.data.sellerId));
      allow update: if isAuthenticated() && isValidProduct(request.resource.data) && (isAdmin() || isSeller(resource.data.sellerId));
      allow delete: if isAdmin() || (isAuthenticated() && isSeller(resource.data.sellerId));
    }

    match /orders/{orderId} {
      // Only admins or the customer who placed the order can read it
      allow read: if isAdmin() || isOrderOwner(resource.data);
      // Anyone can place an order (even guests, but we prefer tracking if logged in)
      allow create: if isValidOrder(request.resource.data);
      // Only admins can update order status
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
