{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application, typically an admin or seller.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "seller"],
          "description": "The user's role."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "role"]
    },
    "Seller": {
      "title": "Seller",
      "description": "A seller profile.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "status": {
          "type": "string",
          "enum": ["Active", "Suspended"]
        },
        "joinedDate": {
          "type": "string"
        }
      },
      "required": ["name", "email", "status", "joinedDate"]
    },
    "Product": {
      "title": "Product",
      "description": "A sneaker product.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "gender": { "type": "string", "enum": ["Men", "Women", "Unisex", "Kids"] },
        "color": { "type": "string" },
        "description": { "type": "string" },
        "isNew": { "type": "boolean" },
        "inStock": { "type": "boolean" },
        "sellerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "brand", "price", "image", "category", "gender", "color", "description", "inStock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "customerInfo": {
          "type": "object",
          "properties": {
            "firstName": { "type": "string" },
            "lastName": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "location": { "type": "string" },
            "city": { "type": "string" }
          },
          "required": ["firstName", "lastName", "email", "phone", "location", "city"]
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Shipped", "Delivered", "Cancelled"] },
        "date": { "type": "string" },
        "paymentMethod": { "type": "string" }
      },
      "required": ["customerInfo", "items", "total", "status", "date", "paymentMethod"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user roles and profiles."
    },
    "/sellers/{sellerId}": {
      "schema": { "$ref": "#/entities/Seller" },
      "description": "Stores seller profiles."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Stores all products."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores all customer orders."
    }
  }
}
