{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and preferences",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "phone": { "type": "string", "description": "User's phone number" },
        "location": { "type": "string", "description": "User's delivery location" },
        "city": { "type": "string", "description": "User's city" }
      },
      "required": ["id", "email", "displayName"]
    },
    "Seller": {
      "title": "Seller",
      "description": "Information about a seller in the marketplace",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the seller" },
        "name": { "type": "string", "description": "Seller's business name" },
        "email": { "type": "string", "format": "email", "description": "Seller's contact email" },
        "status": { "type": "string", "enum": ["Active", "Suspended"], "description": "Current status of the seller" },
        "joinedDate": { "type": "string", "format": "date", "description": "Date the seller joined" }
      },
      "required": ["id", "name", "email", "status", "joinedDate"]
    },
    "Product": {
      "title": "Product",
      "description": "Footwear product details",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the product" },
        "name": { "type": "string", "description": "Product name" },
        "brand": { "type": "string", "description": "Product brand" },
        "price": { "type": "number", "description": "Current price of the product" },
        "originalPrice": { "type": "number", "description": "Original price before discount" },
        "image": { "type": "string", "description": "URL to the product image" },
        "category": { "type": "string", "description": "Product category" },
        "gender": { "type": "string", "enum": ["Men", "Women", "Unisex", "Kids"], "description": "Target gender" },
        "color": { "type": "string", "description": "Product color" },
        "description": { "type": "string", "description": "Product description" },
        "isNew": { "type": "boolean", "description": "Whether the product is new" },
        "inStock": { "type": "boolean", "description": "Whether the product is in stock" },
        "stock": { "type": "number", "description": "Available inventory count" },
        "sellerId": { "type": "string", "description": "ID of the seller who owns this product" }
      },
      "required": ["id", "name", "brand", "price", "image", "category", "gender", "color", "description", "inStock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the order" },
        "userId": { "type": "string", "description": "ID of the customer who placed the order" },
        "sellerIds": { "type": "array", "items": { "type": "string" }, "description": "IDs of the sellers involved in the order" },
        "customerInfo": {
          "type": "object",
          "properties": {
            "firstName": { "type": "string" },
            "lastName": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" },
            "location": { "type": "string" },
            "city": { "type": "string" }
          },
          "required": ["firstName", "lastName", "email", "phone", "location", "city"]
        },
        "items": { "type": "array", "description": "List of products in the order" },
        "total": { "type": "number", "description": "Total order amount" },
        "deliveryFee": { "type": "number", "description": "Delivery fee for the order" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Shipped", "Delivered", "Cancelled"], "description": "Current order status" },
        "date": { "type": "string", "format": "date-time", "description": "Date and time the order was placed" },
        "paymentMethod": { "type": "string", "description": "Payment method used" },
        "mpesaReceipt": { "type": "string", "description": "M-Pesa receipt code" },
        "paymentStatus": { "type": "string", "enum": ["Paid", "Failed", "Pending"], "description": "Payment status" },
        "verificationMethod": { "type": "string", "enum": ["Automatic", "Manual"], "description": "How the payment was verified" }
      },
      "required": ["id", "customerInfo", "items", "total", "status", "date", "paymentMethod"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer review for a product",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the review" },
        "productId": { "type": "string", "description": "ID of the product being reviewed" },
        "userId": { "type": "string", "description": "ID of the user who wrote the review" },
        "userName": { "type": "string", "description": "Name of the reviewer" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5, "description": "Star rating from 1 to 5" },
        "comment": { "type": "string", "description": "Review text" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the review was created" }
      },
      "required": ["id", "productId", "userId", "userName", "rating", "comment", "createdAt"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global business information and settings",
      "type": "object",
      "properties": {
        "businessName": { "type": "string" },
        "logo": { "type": "string" },
        "favicon": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "phoneNumbers": { "type": "array", "items": { "type": "string" } },
        "whatsappNumber": { "type": "string" },
        "location": { "type": "string" },
        "googleMapsEmbed": { "type": "string" },
        "socialMedia": {
          "type": "object",
          "properties": {
            "facebook": { "type": "string" },
            "instagram": { "type": "string" },
            "twitter": { "type": "string" },
            "linkedin": { "type": "string" }
          }
        },
        "footerText": { "type": "string" },
        "seo": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "currency": { "type": "string" },
        "deliveryFee": { "type": "number" },
        "taxPercentage": { "type": "number" },
        "openingHours": { "type": "string" }
      }
    },
    "ThemeSettings": {
      "title": "Theme Settings",
      "description": "UI appearance customization",
      "type": "object",
      "properties": {
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "fontFamily": { "type": "string" },
        "borderRadius": { "type": "string" },
        "darkMode": { "type": "boolean" },
        "buttonStyle": { "type": "string", "enum": ["pill", "rounded", "sharp"] }
      }
    },
    "ContentBlock": {
      "title": "Content Block",
      "description": "Reusable content pieces like policy pages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "slug", "title", "content"]
    },
    "FeatureToggles": {
      "title": "Feature Toggles",
      "description": "Enable or disable application features",
      "type": "object",
      "properties": {
        "enableReviews": { "type": "boolean" },
        "enableCoupons": { "type": "boolean" },
        "enableWishlist": { "type": "boolean" },
        "enablePickupStation": { "type": "boolean" },
        "enableGuestCheckout": { "type": "boolean" },
        "maintenanceMode": { "type": "boolean" }
      }
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Promotional banners and popups",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["banner", "popup", "notice"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "link": { "type": "string" },
        "active": { "type": "boolean" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "mobileOnly": { "type": "boolean" },
        "desktopOnly": { "type": "boolean" }
      },
      "required": ["id", "type", "title", "active"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "Messages sent from contact forms",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read", "replied"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "message", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/sellers/{sellerId}": {
      "schema": "Seller",
      "description": "Seller information"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/settings/site": {
      "schema": "SiteSettings",
      "description": "Global site settings"
    },
    "/settings/theme": {
      "schema": "ThemeSettings",
      "description": "App theme settings"
    },
    "/settings/features": {
      "schema": "FeatureToggles",
      "description": "Feature flags"
    },
    "/content_blocks/{blockId}": {
      "schema": "ContentBlock",
      "description": "Static content blocks"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Marketing announcements"
    },
    "/contact_messages/{messageId}": {
      "schema": "ContactMessage",
      "description": "Contact form submissions"
    }
  }
}
